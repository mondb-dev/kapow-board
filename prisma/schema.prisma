generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  image        String?
  githubId     String   @unique
  cards        Card[]   @relation("AssignedCards")
  createdCards Card[]   @relation("CreatedCards")
  createdAt    DateTime @default(now())
}

model Card {
  id           String       @id @default(cuid())
  title        String
  description  String
  status       CardStatus   @default(BACKLOG)
  assigneeType AssigneeType @default(UNASSIGNED)
  assigneeId   String?
  assignee     User?        @relation("AssignedCards", fields: [assigneeId], references: [id])
  creatorId    String?
  creator      User?        @relation("CreatedCards", fields: [creatorId], references: [id])
  runId        String?
  phaseId      String?
  taskId       String?
  repoUrl      String?
  deployUrl    String?
  events       CardEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([runId])
  @@index([taskId])
}

model CardEvent {
  id        String    @id @default(cuid())
  cardId    String
  card      Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  message   String
  type      EventType @default(INFO)
  createdAt DateTime  @default(now())
}

enum CardStatus {
  BACKLOG
  IN_PROGRESS
  QA
  DONE
  FAILED
}

enum AssigneeType {
  UNASSIGNED
  HUMAN
  AGENT
}

enum EventType {
  INFO
  SUCCESS
  ERROR
  PROGRESS
}
